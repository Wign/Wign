# Dev image only. The production image (./Dockerfile) is unchanged and still
# targets PHP 7.2 + modsecurity. This dev image is aligned with composer.json
# (php ^8.0) and the host-installed vendor/ so it runs on a current machine.
FROM php:8.0-apache
LABEL maintainer="Troels Madsen <tm@wign.dk>"

# PHP extensions (pdo_mysql + opcache need no extra apt packages), mod_rewrite,
# and silence E_DEPRECATED so Laravel 6 doesn't turn PHP 8.x deprecation
# notices into fatal exceptions.
RUN docker-php-ext-install -j"$(nproc)" pdo_mysql opcache \
    && a2enmod rewrite \
    && echo 'error_reporting = E_ALL & ~E_DEPRECATED & ~E_STRICT' \
       > /usr/local/etc/php/conf.d/zz-wign-dev.ini

WORKDIR /var/www

EXPOSE 80

# Apache vhost (DocumentRoot = /var/www/public). The project itself — including
# vendor/ — is bind-mounted over /var/www at runtime (see docker-compose.yaml).
ADD apache/000-default.conf /etc/apache2/sites-available/000-default.conf
ADD apache/prod.htaccess /var/www/public/.htaccess

# Switch www-data's UID to match the developer so Apache can serve the
# bind-mounted files that are owned by the host user.
ARG userid=1000
ARG groupid=1000
RUN usermod -u ${userid} www-data || true
